include "test"
| include "gha"
|

let ci_workflow = "name: CI\non:\n  push:\n    branches:\n      - main\n  pull_request:\n    branches:\n      - main\npermissions:\n  contents: read\njobs:\n  build:\n    runs-on: ubuntu-latest\n    env:\n      RUST_LOG: debug\n    steps:\n      - uses: actions/checkout@v4\n        with:\n          persist-credentials: false\n      - name: Run tests\n        run: cargo test\n  lint:\n    runs-on: ubuntu-latest\n    needs: build\n    steps:\n      - uses: actions/checkout@v4\n      - name: Lint\n        run: cargo clippy\n"

| let dispatch_workflow = "name: Release\non:\n  workflow_dispatch:\n    inputs:\n      version:\n        description: Version to release\n        required: true\n        type: string\n      dry_run:\n        description: Dry run\n        required: false\n        type: boolean\njobs:\n  release:\n    runs-on: ubuntu-latest\n    steps:\n      - uses: actions/checkout@v4\n      - name: Build\n        run: cargo build --release\n"

| let matrix_workflow = "name: Matrix\non:\n  push:\n    branches:\n      - main\njobs:\n  test:\n    runs-on: ubuntu-latest\n    strategy:\n      matrix:\n        os:\n          - ubuntu-latest\n          - macos-latest\n        rust:\n          - stable\n          - beta\n    steps:\n      - uses: actions/checkout@v4\n      - name: Test\n        run: cargo test\n"

| let step_env_workflow = "name: Step Env\non:\n  push:\n    branches:\n      - main\njobs:\n  build:\n    runs-on: ubuntu-latest\n    steps:\n      - name: Deploy\n        run: echo deploy\n        env:\n          TOKEN: secret\n          REGION: us-east-1\n"

|

# -- gha_parse --

def test_gha_parse_returns_dict():
  let result = gha_parse(ci_workflow)
  | assert(is_dict(result))
end

def test_gha_parse_has_expected_keys():
  let result = gha_parse(ci_workflow)
  | assert(!is_none(result["name"]))
  | assert(!is_none(result["jobs"]))
end

# -- gha_name --

def test_gha_name():
  let wf = gha_parse(ci_workflow)
  | assert_eq(gha_name(wf), "CI")
end

# -- gha_triggers --

def test_gha_triggers_not_none():
  let wf = gha_parse(ci_workflow)
  | assert(!is_none(gha_triggers(wf)))
end

def test_gha_triggers_has_push():
  let wf = gha_parse(ci_workflow)
  | let triggers = gha_triggers(wf)
  | assert(!is_none(triggers["push"]))
end

def test_gha_triggers_has_pull_request():
  let wf = gha_parse(ci_workflow)
  | let triggers = gha_triggers(wf)
  | assert(!is_none(triggers["pull_request"]))
end

# -- gha_jobs --

def test_gha_jobs_returns_dict():
  let wf = gha_parse(ci_workflow)
  | assert(is_dict(gha_jobs(wf)))
end

def test_gha_job_names():
  let wf = gha_parse(ci_workflow)
  | let names = gha_job_names(wf)
  | assert_eq(len(names), 2)
  | assert(fold(names, false, fn(acc, n): acc || n == "build";))
  | assert(fold(names, false, fn(acc, n): acc || n == "lint";))
end

# -- gha_steps --

def test_gha_steps_count():
  let wf = gha_parse(ci_workflow)
  | let jobs = gha_jobs(wf)
  | let steps = gha_steps(jobs["build"])
  | assert_eq(len(steps), 2)
end

def test_gha_steps_empty_for_missing():
  let result = gha_steps(dict())
  | assert_eq(result, [])
end

# -- gha_uses --

def test_gha_uses():
  let wf = gha_parse(ci_workflow)
  | let step = first(gha_steps(gha_jobs(wf)["build"]))
  | assert_eq(gha_uses(step), "actions/checkout@v4")
end

# -- gha_run --

def test_gha_run():
  let wf = gha_parse(ci_workflow)
  | let steps = gha_steps(gha_jobs(wf)["build"])
  | let run_step = steps[1]
  | assert_eq(gha_run(run_step), "cargo test")
end

# -- gha_step_name --

def test_gha_step_name():
  let wf = gha_parse(ci_workflow)
  | let steps = gha_steps(gha_jobs(wf)["build"])
  | assert_eq(gha_step_name(steps[1]), "Run tests")
end

# -- gha_step_with --

def test_gha_step_with():
  let wf = gha_parse(ci_workflow)
  | let step = first(gha_steps(gha_jobs(wf)["build"]))
  | let w = gha_step_with(step)
  | assert(!is_none(w["persist-credentials"]))
  | assert_eq(w["persist-credentials"], false)
end

def test_gha_step_with_empty_for_missing():
  let wf = gha_parse(ci_workflow)
  | let steps = gha_steps(gha_jobs(wf)["build"])
  | let w = gha_step_with(steps[1])
  | assert_eq(len(keys(w)), 0)
end

# -- gha_env --

def test_gha_env_on_job():
  let wf = gha_parse(ci_workflow)
  | let job = gha_jobs(wf)["build"]
  | let env = gha_env(job)
  | assert_eq(env["RUST_LOG"], "debug")
end

def test_gha_env_empty_for_missing():
  let wf = gha_parse(ci_workflow)
  | let env = gha_env(wf)
  | assert_eq(len(keys(env)), 0)
end

# -- gha_permissions --

def test_gha_permissions():
  let wf = gha_parse(ci_workflow)
  | let perms = gha_permissions(wf)
  | assert_eq(perms["contents"], "read")
end

def test_gha_permissions_empty_for_missing():
  let result = gha_permissions(dict())
  | assert_eq(len(keys(result)), 0)
end

# -- gha_job_needs --

def test_gha_job_needs_string():
  let wf = gha_parse(ci_workflow)
  | let lint = gha_jobs(wf)["lint"]
  | let needs = gha_job_needs(lint)
  | assert_eq(needs, ["build"])
end

def test_gha_job_needs_empty():
  let wf = gha_parse(ci_workflow)
  | let build = gha_jobs(wf)["build"]
  | assert_eq(gha_job_needs(build), [])
end

# -- gha_inputs --

def test_gha_inputs():
  let wf = gha_parse(dispatch_workflow)
  | let inputs = gha_inputs(wf)
  | assert(!is_none(inputs["version"]))
  | assert(!is_none(inputs["dry_run"]))
end

def test_gha_inputs_empty_for_push_workflow():
  let wf = gha_parse(ci_workflow)
  | let inputs = gha_inputs(wf)
  | assert_eq(len(keys(inputs)), 0)
end

# -- gha_matrix --

def test_gha_matrix_none_when_absent():
  let wf = gha_parse(ci_workflow)
  | let build = gha_jobs(wf)["build"]
  | assert_none(gha_matrix(build))
end

# -- gha_find_steps_by_uses --

def test_gha_find_steps_by_uses():
  let wf = gha_parse(ci_workflow)
  | let steps = gha_find_steps_by_uses(wf, "actions/checkout")
  | assert_eq(len(steps), 2)
end

def test_gha_find_steps_by_uses_no_match():
  let wf = gha_parse(ci_workflow)
  | let steps = gha_find_steps_by_uses(wf, "docker/build-push-action")
  | assert_eq(len(steps), 0)
end

# -- gha_matrix --

def test_gha_matrix_values():
  let wf = gha_parse(matrix_workflow)
  | let job = gha_jobs(wf)["test"]
  | let matrix = gha_matrix(job)
  | assert(!is_none(matrix))
  | assert(!is_none(matrix["os"]))
  | assert(!is_none(matrix["rust"]))
  | assert_eq(len(matrix["os"]), 2)
  | assert_eq(len(matrix["rust"]), 2)
end

def test_gha_matrix_os_values():
  let wf = gha_parse(matrix_workflow)
  | let matrix = gha_matrix(gha_jobs(wf)["test"])
  | assert(fold(matrix["os"], false, fn(acc, v): acc || v == "ubuntu-latest";))
  | assert(fold(matrix["os"], false, fn(acc, v): acc || v == "macos-latest";))
end

# -- gha_env on step --

def test_gha_env_on_step():
  let wf = gha_parse(step_env_workflow)
  | let step = first(gha_steps(gha_jobs(wf)["build"]))
  | let env = gha_env(step)
  | assert_eq(env["TOKEN"], "secret")
  | assert_eq(env["REGION"], "us-east-1")
end

def test_gha_env_empty_on_step_without_env():
  let wf = gha_parse(ci_workflow)
  | let step = first(gha_steps(gha_jobs(wf)["build"]))
  | assert_eq(len(keys(gha_env(step))), 0)
end

# -- gha_job_needs with array --

def test_gha_job_needs_array():
  let wf = gha_parse("name: W\non:\n  push:\n    branches:\n      - main\njobs:\n  deploy:\n    runs-on: ubuntu-latest\n    needs:\n      - build\n      - test\n    steps:\n      - run: echo done\n")
  | let needs = gha_job_needs(gha_jobs(wf)["deploy"])
  | assert_eq(len(needs), 2)
  | assert(fold(needs, false, fn(acc, n): acc || n == "build";))
  | assert(fold(needs, false, fn(acc, n): acc || n == "test";))
end

# -- gha_triggers branch filters --

def test_gha_triggers_push_branches():
  let wf = gha_parse(ci_workflow)
  | let push = gha_triggers(wf)["push"]
  | assert_eq(len(push["branches"]), 1)
  | assert_eq(first(push["branches"]), "main")
end

def test_gha_triggers_pull_request_branches():
  let wf = gha_parse(ci_workflow)
  | let pr = gha_triggers(wf)["pull_request"]
  | assert_eq(first(pr["branches"]), "main")
end

# -- gha_inputs field detail --

def test_gha_inputs_version_required():
  let wf = gha_parse(dispatch_workflow)
  | let inputs = gha_inputs(wf)
  | assert_eq(inputs["version"]["required"], true)
  | assert_eq(inputs["version"]["type"], "string")
end

def test_gha_inputs_dry_run_optional():
  let wf = gha_parse(dispatch_workflow)
  | let inputs = gha_inputs(wf)
  | assert_eq(inputs["dry_run"]["required"], false)
  | assert_eq(inputs["dry_run"]["type"], "boolean")
end

def test_gha_inputs_no_workflow_dispatch():
  let wf = gha_parse("name: W\non:\n  schedule:\n    - cron: '0 0 * * *'\njobs:\n  job:\n    runs-on: ubuntu-latest\n    steps:\n      - run: echo hi\n")
  | assert_eq(len(keys(gha_inputs(wf))), 0)
end

def test_gha_inputs_dispatch_without_inputs():
  let wf = gha_parse("name: W\non:\n  workflow_dispatch:\njobs:\n  job:\n    runs-on: ubuntu-latest\n    steps:\n      - run: echo hi\n")
  | assert_eq(len(keys(gha_inputs(wf))), 0)
end

# -- gha_find_steps_by_uses pattern variants --

def test_gha_find_steps_by_uses_versioned():
  let wf = gha_parse(ci_workflow)
  | let steps = gha_find_steps_by_uses(wf, "actions/checkout@v4")
  | assert_eq(len(steps), 2)
end

def test_gha_find_steps_by_uses_across_jobs():
  let wf = gha_parse(dispatch_workflow)
  | let steps = gha_find_steps_by_uses(wf, "actions/checkout")
  | assert_eq(len(steps), 1)
end

# -- gha_stringify --

def test_gha_stringify_returns_string():
  let wf = gha_parse(ci_workflow)
  | assert(is_string(gha_stringify(wf)))
end

def test_gha_stringify_contains_name():
  let wf = gha_parse(ci_workflow)
  | let yaml = gha_stringify(wf)
  | assert(contains(yaml, "CI"))
end

def test_gha_stringify_contains_job_names():
  let wf = gha_parse(ci_workflow)
  | let yaml = gha_stringify(wf)
  | assert(contains(yaml, "build"))
  | assert(contains(yaml, "lint"))
end

def test_gha_stringify_contains_runs_on():
  let wf = gha_parse(ci_workflow)
  | let yaml = gha_stringify(wf)
  | assert(contains(yaml, "ubuntu-latest"))
end

def test_gha_stringify_contains_step_uses():
  let wf = gha_parse(ci_workflow)
  | let yaml = gha_stringify(wf)
  | assert(contains(yaml, "actions/checkout@v4"))
end

def test_gha_stringify_contains_step_run():
  let wf = gha_parse(ci_workflow)
  | let yaml = gha_stringify(wf)
  | assert(contains(yaml, "cargo test"))
  | assert(contains(yaml, "cargo clippy"))
end

def test_gha_stringify_contains_permissions():
  let wf = gha_parse(ci_workflow)
  | let yaml = gha_stringify(wf)
  | assert(contains(yaml, "contents"))
  | assert(contains(yaml, "read"))
end

def test_gha_stringify_contains_env():
  let wf = gha_parse(ci_workflow)
  | let yaml = gha_stringify(wf)
  | assert(contains(yaml, "RUST_LOG"))
  | assert(contains(yaml, "debug"))
end

def test_gha_stringify_roundtrip_name():
  let wf = gha_parse(ci_workflow)
  | let reparsed = gha_parse(gha_stringify(wf))
  | assert_eq(gha_name(reparsed), "CI")
end

def test_gha_stringify_roundtrip_job_names():
  let wf = gha_parse(ci_workflow)
  | let reparsed = gha_parse(gha_stringify(wf))
  | let names = gha_job_names(reparsed)
  | assert_eq(len(names), 2)
  | assert(fold(names, false, fn(acc, n): acc || n == "build";))
  | assert(fold(names, false, fn(acc, n): acc || n == "lint";))
end

def test_gha_stringify_roundtrip_step_count():
  let wf = gha_parse(ci_workflow)
  | let reparsed = gha_parse(gha_stringify(wf))
  | assert_eq(len(gha_steps(gha_jobs(reparsed)["build"])), 2)
  | assert_eq(len(gha_steps(gha_jobs(reparsed)["lint"])), 2)
end

def test_gha_stringify_roundtrip_permissions():
  let wf = gha_parse(ci_workflow)
  | let reparsed = gha_parse(gha_stringify(wf))
  | assert_eq(gha_permissions(reparsed)["contents"], "read")
end

def test_gha_stringify_roundtrip_job_needs():
  let wf = gha_parse(ci_workflow)
  | let reparsed = gha_parse(gha_stringify(wf))
  | assert_eq(gha_job_needs(gha_jobs(reparsed)["lint"]), ["build"])
end

def test_gha_stringify_roundtrip_env():
  let wf = gha_parse(ci_workflow)
  | let reparsed = gha_parse(gha_stringify(wf))
  | assert_eq(gha_env(gha_jobs(reparsed)["build"])["RUST_LOG"], "debug")
end

def test_gha_stringify_roundtrip_step_with():
  let wf = gha_parse(ci_workflow)
  | let reparsed = gha_parse(gha_stringify(wf))
  | let step = first(gha_steps(gha_jobs(reparsed)["build"]))
  | assert_eq(gha_step_with(step)["persist-credentials"], false)
end

def test_gha_stringify_roundtrip_triggers():
  let wf = gha_parse(ci_workflow)
  | let reparsed = gha_parse(gha_stringify(wf))
  | let triggers = gha_triggers(reparsed)
  | assert(!is_none(triggers["push"]))
  | assert(!is_none(triggers["pull_request"]))
end

def test_gha_stringify_roundtrip_matrix():
  let wf = gha_parse(matrix_workflow)
  | let reparsed = gha_parse(gha_stringify(wf))
  | let matrix = gha_matrix(gha_jobs(reparsed)["test"])
  | assert(!is_none(matrix))
  | assert_eq(len(matrix["os"]), 2)
  | assert_eq(len(matrix["rust"]), 2)
end

def test_gha_stringify_roundtrip_dispatch_inputs():
  let wf = gha_parse(dispatch_workflow)
  | let reparsed = gha_parse(gha_stringify(wf))
  | let inputs = gha_inputs(reparsed)
  | assert(!is_none(inputs["version"]))
  | assert(!is_none(inputs["dry_run"]))
  | assert_eq(inputs["version"]["required"], true)
  | assert_eq(inputs["dry_run"]["required"], false)
end

def test_gha_stringify_roundtrip_step_env():
  let wf = gha_parse(step_env_workflow)
  | let reparsed = gha_parse(gha_stringify(wf))
  | let step = first(gha_steps(gha_jobs(reparsed)["build"]))
  | assert_eq(gha_env(step)["TOKEN"], "secret")
  | assert_eq(gha_env(step)["REGION"], "us-east-1")
end

def test_gha_stringify_roundtrip_uses():
  let wf = gha_parse(ci_workflow)
  | let reparsed = gha_parse(gha_stringify(wf))
  | let step = first(gha_steps(gha_jobs(reparsed)["build"]))
  | assert_eq(gha_uses(step), "actions/checkout@v4")
end

def test_gha_stringify_roundtrip_step_run():
  let wf = gha_parse(ci_workflow)
  | let reparsed = gha_parse(gha_stringify(wf))
  | let steps = gha_steps(gha_jobs(reparsed)["build"])
  | assert_eq(gha_run(steps[1]), "cargo test")
end

def test_gha_stringify_roundtrip_step_name():
  let wf = gha_parse(ci_workflow)
  | let reparsed = gha_parse(gha_stringify(wf))
  | let steps = gha_steps(gha_jobs(reparsed)["build"])
  | assert_eq(gha_step_name(steps[1]), "Run tests")
end

# -- gha_to_markdown_table --

def test_gha_to_markdown_table():
  let wf = gha_parse(ci_workflow)
  | let table = gha_to_markdown_table(wf)
  | assert(is_string(table))
  | assert(contains(table, "build"))
  | assert(contains(table, "lint"))
  | assert(contains(table, "ubuntu-latest"))
end
